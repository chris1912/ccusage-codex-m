if [[ -n "${USERPROFILE:-}" ]] && command -v cygpath >/dev/null 2>&1; then
  codex_home="$(cygpath -m "$USERPROFILE/.codex")"
else
  codex_home="$HOME/.codex"
fi

export CODEX_HOME="$codex_home"

ccusage-codex-m() {
  node "$codex_home/ccusage_m_view.js" daily "$@"
}

ccusage-codex-monthly() {
  node "$codex_home/ccusage_m_view.js" monthly "$@"
}

ccusage-codex-open() {
  node "$codex_home/ccusage_m_view.js" sessions "$@"
}
